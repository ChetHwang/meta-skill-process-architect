%% State Machine Starter Template
%% For L1.6 — process states + transitions
%% Mark terminal states explicitly

stateDiagram-v2
    [*] --> Initiated: trigger event
    Initiated --> InProgress: S1 begins
    InProgress --> PendingApproval: S3 submitted
    PendingApproval --> InProgress: rejection (S3.E)
    PendingApproval --> Completed: approval (S4)
    InProgress --> Escalated: SLA breach
    Escalated --> InProgress: escalation resolved
    InProgress --> Cancelled: user cancels
    Completed --> [*]
    Cancelled --> [*]

    note right of PendingApproval
        Track time-in-state
        Alert if > SLA
    end note
